{
    "name": "auto_AU_kb.isc.org_ddu",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://kb.isc.org/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?kb\\.isc\\.org/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > d360-ui-root:not([id]) > div:nth-child(3):not([id]) > d360-cookie-consent:nth-child(1):not([id]) > div:not([id]) > button:nth-child(2):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > d360-ui-root:not([id]) > div:nth-child(3):not([id]) > d360-cookie-consent:nth-child(1):not([id]) > div:not([id]) > button:nth-child(2):not([id])"
        }
    ],
    "optIn": [],
