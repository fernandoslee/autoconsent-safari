        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > d360-ui-root:not([id]) > div:nth-child(3):not([id]) > d360-cookie-consent:nth-child(1):not([id]) > div:not([id]) > button:nth-child(2):not([id])",
            "comment": "Accept necessary cookies"
        }
