{
    "name": "auto_GB_easyframe.co.uk_sug",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.easyframe.co.uk/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?easyframe\\.co\\.uk/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#kcookieinfo > div:nth-child(2)#kcookieinfobutton > a:nth-child(1)#kcookieinfodecline"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#kcookieinfo > div:nth-child(2)#kcookieinfobutton > a:nth-child(1)#kcookieinfodecline"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#kcookieinfo > div:nth-child(2)#kcookieinfobutton > a:nth-child(1)#kcookieinfodecline",
            "comment": "DECLINE"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#kcookieinfo > div:nth-child(2)#kcookieinfobutton > a:nth-child(1)#kcookieinfodecline",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
