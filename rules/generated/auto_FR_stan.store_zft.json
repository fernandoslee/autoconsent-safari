{
    "name": "auto_FR_stan.store_zft",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.stan.store/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?stan\\.store/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div:not([id]) > div:nth-child(2):not([id]) > div:nth-child(2)#reject-cookies"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div:not([id]) > div:nth-child(2):not([id]) > div:nth-child(2)#reject-cookies"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div:not([id]) > div:nth-child(2):not([id]) > div:nth-child(2)#reject-cookies",
            "comment": "Reject"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div:not([id]) > div:nth-child(2):not([id]) > div:nth-child(2)#reject-cookies",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
