{
    "name": "auto_CH_organizzazione.cai.it_nzs",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://organizzazione.cai.it/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?cai\\.it/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookie-notice-consent > div:not([id]) > div:nth-child(3):not([id]) > a:nth-child(3)#cookie-notice-consent__reject-button"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookie-notice-consent > div:not([id]) > div:nth-child(3):not([id]) > a:nth-child(3)#cookie-notice-consent__reject-button"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookie-notice-consent > div:not([id]) > div:nth-child(3):not([id]) > a:nth-child(3)#cookie-notice-consent__reject-button",
            "comment": "Rifiuta"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookie-notice-consent > div:not([id]) > div:nth-child(3):not([id]) > a:nth-child(3)#cookie-notice-consent__reject-button",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
