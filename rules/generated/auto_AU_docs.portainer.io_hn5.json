{
    "name": "auto_AU_docs.portainer.io_hn5",
    "vendorUrl": "https://docs.portainer.io/",
    "cosmetic": false,
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?docs\\.portainer\\.io/"
    },
    "prehideSelectors": ["[data-testid=\"cookies-dialog\"]"],
    "detectCmp": [
        {
            "exists": "[data-testid=\"cookies-dialog\"]"
        }
    ],
    "detectPopup": [
        {
            "visible": "[data-testid=\"cookies-dialog\"]"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "[aria-label=\"Accept\"]"
        }
    ],
    "optOut": [
        {
