{
    "name": "auto_DE_aerztekammer-bw.de_rse",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.aerztekammer-bw.de/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?aerztekammer-bw\\.de/"
    },
    "prehideSelectors": ["div.cookie-banner"],
    "detectCmp": [
        {
            "exists": "div.cookie-banner"
        }
    ],
    "detectPopup": [
        {
            "visible": "div.cookie-banner"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "xpath///button[contains(., 'Alle akzeptieren')] | //a[contains(., 'Alle akzeptieren')]"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": "a.cookie-button.cookie-link"
        }
    ]
}
