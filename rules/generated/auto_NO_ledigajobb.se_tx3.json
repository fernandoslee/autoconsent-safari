{
    "name": "auto_NO_ledigajobb.se_tx3",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://ledigajobb.se/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?ledigajobb\\.se/"
    },
    "prehideSelectors": ["#cookie-consent-modal"],
    "detectCmp": [
        {
            "exists": "#cookie-consent-modal"
        }
    ],
    "detectPopup": [
        {
            "visible": "#cookie-consent-modal"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "div.pt-3 > button:nth-of-type(1)"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": "div.pt-3 > button:nth-of-type(2)"
        }
    ]
}
