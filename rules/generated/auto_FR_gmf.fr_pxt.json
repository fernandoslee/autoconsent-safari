{
    "name": "auto_FR_gmf.fr_pxt",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.gmf.fr/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?gmf\\.fr/"
    },
    "prehideSelectors": ["#popin_tc_privacy"],
    "detectCmp": [
        {
            "exists": "#popin_tc_privacy"
        }
    ],
    "detectPopup": [
        {
            "visible": "#popin_tc_privacy"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "#popin_tc_privacy_button_2"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": "#popin_tc_privacy_button"
        }
    ]
}
