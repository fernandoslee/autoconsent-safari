{
    "name": "auto_NO_plantagen.se_hl8",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.plantagen.se/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?plantagen\\.se/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#radix-«r0» > div:nth-child(4):not([id]) > button:nth-child(2):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#radix-«r0» > div:nth-child(4):not([id]) > button:nth-child(2):not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#radix-«r0» > div:nth-child(4):not([id]) > button:nth-child(2):not([id])",
            "comment": "Godta endast nödvändiga"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#radix-«r0» > div:nth-child(4):not([id]) > button:nth-child(2):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
