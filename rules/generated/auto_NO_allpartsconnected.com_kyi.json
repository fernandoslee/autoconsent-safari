{
    "name": "auto_NO_allpartsconnected.com_kyi",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.allpartsconnected.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?allpartsconnected\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div:not([id]) > a:nth-child(2):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div:not([id]) > a:nth-child(2):not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div:not([id]) > a:nth-child(2):not([id])",
            "comment": "DENY"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div:not([id]) > a:nth-child(2):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
