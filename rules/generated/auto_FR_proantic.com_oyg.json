{
    "name": "auto_FR_proantic.com_oyg",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.proantic.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?proantic\\.com/"
    },
    "prehideSelectors": ["#cookie"],
    "detectCmp": [
        {
            "exists": "#cookie"
        }
    ],
    "detectPopup": [
        {
            "visible": "#cookie"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "#Buttondivanalytic > button:nth-of-type(1)"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": "#Buttondivanalytic > button:nth-of-type(2)"
        }
    ]
}
