{
    "name": "auto_FR_ludum.fr_gl5",
    "cosmetic": true,
    "_metadata": {
        "vendorUrl": "http://www.ludum.fr/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?ludum\\.fr/"
    },
    "prehideSelectors": ["#cookiesplus-content"],
    "detectCmp": [
        {
            "exists": "#cookiesplus-content"
        }
    ],
    "detectPopup": [
        {
            "visible": "#cookiesplus-content"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "div.col-xs-12 > button:nth-of-type(1)"
        }
    ],
    "optOut": [
        {
            "hide": "#cookiesplus-content"
        }
    ]
}
