{
    "name": "auto_FR_transitionspro-bretagne.fr_krm",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.transitionspro-bretagne.fr/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?transitionspro-bretagne\\.fr/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div:not([id]) > div:nth-child(3):not([id]) > button:nth-child(2)#tracking-consent-close"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div:not([id]) > div:nth-child(3):not([id]) > button:nth-child(2)#tracking-consent-close"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div:not([id]) > div:nth-child(3):not([id]) > button:nth-child(2)#tracking-consent-close",
            "comment": "Refuser"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div:not([id]) > div:nth-child(3):not([id]) > button:nth-child(2)#tracking-consent-close",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
