{
    "name": "auto_GB_easymtd.com_ice",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://easymtd.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?easymtd\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookieFirstVisitModal > div:not([id]) > div:not([id]) > div:nth-child(3):not([id]) > button:nth-child(1)#cookie-first-reject-all-btn"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookieFirstVisitModal > div:not([id]) > div:not([id]) > div:nth-child(3):not([id]) > button:nth-child(1)#cookie-first-reject-all-btn"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookieFirstVisitModal > div:not([id]) > div:not([id]) > div:nth-child(3):not([id]) > button:nth-child(1)#cookie-first-reject-all-btn",
            "comment": "REJECT"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookieFirstVisitModal > div:not([id]) > div:not([id]) > div:nth-child(3):not([id]) > button:nth-child(1)#cookie-first-reject-all-btn",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
