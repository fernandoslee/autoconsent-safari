{
    "name": "auto_DE_simplyprint.io_wlr",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://simplyprint.io/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?simplyprint\\.io/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#sp-consent-banner > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(2):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#sp-consent-banner > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(2):not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#sp-consent-banner > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(2):not([id])",
            "comment": "Necessary only"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#sp-consent-banner > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(2):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
