{
    "name": "auto_NO_gyhockey.com_qyd",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.gyhockey.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?gyhockey\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#privacy-prompt > div:nth-child(3):not([id]) > a:nth-child(1)#reject-btn"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#privacy-prompt > div:nth-child(3):not([id]) > a:nth-child(1)#reject-btn"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#privacy-prompt > div:nth-child(3):not([id]) > a:nth-child(1)#reject-btn",
            "comment": "Reject"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#privacy-prompt > div:nth-child(3):not([id]) > a:nth-child(1)#reject-btn",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
