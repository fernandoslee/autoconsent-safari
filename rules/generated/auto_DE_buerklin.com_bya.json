{
    "name": "auto_DE_buerklin.com_bya",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.buerklin.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?buerklin\\.com/"
    },
    "prehideSelectors": ["#ccm-widget"],
    "detectCmp": [
        {
            "exists": "#ccm-widget"
        }
    ],
    "detectPopup": [
        {
            "visible": "#ccm-widget"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "[aria-label=\"Agree\"]"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": "button.ccm--decline-cookies"
        }
    ]
}
