{
    "name": "auto_CH_astag.ch_1if",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.astag.ch/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?astag\\.ch/"
    },
    "prehideSelectors": ["#cookie-consent"],
    "detectCmp": [
        {
            "exists": "#cookie-consent"
        }
    ],
    "detectPopup": [
        {
            "visible": "#cookie-consent"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "button.save"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": "button.deny"
        }
    ]
}
