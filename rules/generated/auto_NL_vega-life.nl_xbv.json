{
    "name": "auto_NL_vega-life.nl_xbv",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.vega-life.nl/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?vega-life\\.nl/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookie-banner > div:nth-child(1):not([id]) > div:nth-child(2):not([id]) > button:nth-child(1)#decline-cookies"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookie-banner > div:nth-child(1):not([id]) > div:nth-child(2):not([id]) > button:nth-child(1)#decline-cookies"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookie-banner > div:nth-child(1):not([id]) > div:nth-child(2):not([id]) > button:nth-child(1)#decline-cookies",
            "comment": "Afwijzen"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookie-banner > div:nth-child(1):not([id]) > div:nth-child(2):not([id]) > button:nth-child(1)#decline-cookies",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
