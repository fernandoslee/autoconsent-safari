{
    "name": "auto_CH_memoriahistorica.org.es_met",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://memoriahistorica.org.es/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?memoriahistorica\\.org\\.es/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookies-eu-wrapper > div#cookies-eu-banner > div:nth-child(2)#cookies-eu-buttons > button:nth-child(1)#cookies-eu-reject"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookies-eu-wrapper > div#cookies-eu-banner > div:nth-child(2)#cookies-eu-buttons > button:nth-child(1)#cookies-eu-reject"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookies-eu-wrapper > div#cookies-eu-banner > div:nth-child(2)#cookies-eu-buttons > button:nth-child(1)#cookies-eu-reject",
            "comment": "RECHAZAR"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookies-eu-wrapper > div#cookies-eu-banner > div:nth-child(2)#cookies-eu-buttons > button:nth-child(1)#cookies-eu-reject",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
