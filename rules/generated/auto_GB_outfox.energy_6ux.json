{
    "name": "auto_GB_outfox.energy_6ux",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://outfox.energy/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?outfox\\.energy/"
    },
    "prehideSelectors": ["div.MuiDrawer-modal.MuiModal-root div.MuiPaper-root"],
    "detectCmp": [
        {
            "exists": "div.MuiDrawer-modal.MuiModal-root div.MuiPaper-root"
        }
    ],
    "detectPopup": [
        {
            "visible": "div.MuiDrawer-modal.MuiModal-root div.MuiPaper-root"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "div.MuiGrid-root > button:nth-of-type(1)"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": "div.MuiGrid-root > button:nth-of-type(2)"
        }
    ]
}
