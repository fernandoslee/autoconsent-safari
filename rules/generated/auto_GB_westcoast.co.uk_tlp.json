{
    "name": "auto_GB_westcoast.co.uk_tlp",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.westcoast.co.uk/"
    },
    "runContext": {
        "main": false,
        "frame": true,
        "urlPattern": "^https?://(www\\.)?analytics-eu\\.clickdimensions\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#modal-overlay > div#modalMain > div:not([id]) > a:nth-child(1)#stopTracking"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#modal-overlay > div#modalMain > div:not([id]) > a:nth-child(1)#stopTracking"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#modal-overlay > div#modalMain > div:not([id]) > a:nth-child(1)#stopTracking",
            "comment": "Disable Tracking"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#modal-overlay > div#modalMain > div:not([id]) > a:nth-child(1)#stopTracking",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
