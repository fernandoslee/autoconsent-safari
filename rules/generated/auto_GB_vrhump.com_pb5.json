{
    "name": "auto_GB_vrhump.com_pb5",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.vrhump.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?vrhump\\.com/"
    },
    "prehideSelectors": ["#cookie-consent-popup"],
    "detectCmp": [
        {
            "exists": "#cookie-consent-popup"
        }
    ],
    "detectPopup": [
        {
            "visible": "#cookie-consent-popup"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "#cookie-accept"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": "#cookie-reject"
        }
    ]
}
