{
    "name": "auto_CA_zenpop.jp_c6j",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://zenpop.jp/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?zenpop\\.jp/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookieConsent > div:not([id]) > div:not([id]) > button:nth-child(4)#decline-cookie-policy"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookieConsent > div:not([id]) > div:not([id]) > button:nth-child(4)#decline-cookie-policy"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookieConsent > div:not([id]) > div:not([id]) > button:nth-child(4)#decline-cookie-policy",
            "comment": "Decline"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookieConsent > div:not([id]) > div:not([id]) > button:nth-child(4)#decline-cookie-policy",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
