{
    "name": "auto_AU_lush.com_bdf",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.lush.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?lush\\.com/"
    },
    "prehideSelectors": ["div.cookie-banner-styles__BannerButtons-sc-d9631133-2"],
    "detectCmp": [
        {
            "exists": "div.cookie-banner-styles__BannerButtons-sc-d9631133-2"
        }
    ],
    "detectPopup": [
        {
            "visible": "div.cookie-banner-styles__BannerButtons-sc-d9631133-2"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "[data-test=\"cookie__accept\"]"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": "[data-test=\"cookie__reject\"]"
        }
    ]
}
