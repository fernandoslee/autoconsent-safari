{
    "name": "auto_NL_gymnasium.farama.org_zed",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://gymnasium.farama.org/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?gymnasium\\.farama\\.org/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div:not([id]) > div:not([id]) > button:nth-child(2)#cookie-alert__decline"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div:not([id]) > div:not([id]) > button:nth-child(2)#cookie-alert__decline"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div:not([id]) > div:not([id]) > button:nth-child(2)#cookie-alert__decline",
            "comment": "Deny"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div:not([id]) > div:not([id]) > button:nth-child(2)#cookie-alert__decline",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
