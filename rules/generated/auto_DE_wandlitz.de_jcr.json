{
    "name": "auto_DE_wandlitz.de_jcr",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.wandlitz.de/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?wandlitz\\.de/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > dialog#portuna_info > div:nth-child(2)#cookie-buttons-div > a:nth-child(3)#cc_btn_decline"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > dialog#portuna_info > div:nth-child(2)#cookie-buttons-div > a:nth-child(3)#cc_btn_decline"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > dialog#portuna_info > div:nth-child(2)#cookie-buttons-div > a:nth-child(3)#cc_btn_decline",
            "comment": "Ablehnen"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > dialog#portuna_info > div:nth-child(2)#cookie-buttons-div > a:nth-child(3)#cc_btn_decline",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
