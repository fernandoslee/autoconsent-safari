{
    "name": "auto_CH_bandlab.com_jul",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.bandlab.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?bandlab\\.com/"
    },
    "prehideSelectors": ["div.privacy-banner"],
    "detectCmp": [
        {
            "exists": "div.privacy-banner"
        }
    ],
    "detectPopup": [
        {
            "visible": "div.privacy-banner"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "div.privacy-banner-footer > button:nth-of-type(3)"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": "div.privacy-banner-footer > button:nth-of-type(2)"
        }
    ]
}
