{
    "name": "auto_CH_taquilla.com_ng6",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.taquilla.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?taquilla\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookies_policy > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(3):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookies_policy > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(3):not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookies_policy > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(3):not([id])",
            "comment": "RECHAZAR TODO"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookies_policy > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(3):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
