{
    "name": "auto_NO_freysta.com_x2b",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.freysta.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?freysta\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > section:not([id]) > div:nth-child(4):not([id]) > button:nth-child(2):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > section:not([id]) > div:nth-child(4):not([id]) > button:nth-child(2):not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > section:not([id]) > div:nth-child(4):not([id]) > button:nth-child(2):not([id])",
            "comment": "REJECT ANALYTICS"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > section:not([id]) > div:nth-child(4):not([id]) > button:nth-child(2):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
