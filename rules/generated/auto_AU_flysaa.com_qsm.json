{
    "name": "auto_AU_flysaa.com_qsm",
    "cosmetic": true,
    "_metadata": {
        "vendorUrl": "https://www.flysaa.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?flysaa\\.com/"
    },
    "prehideSelectors": ["#_es_indra_ibe_saa_CookiesPortlet_cookiesForm"],
    "detectCmp": [
        {
            "exists": "#_es_indra_ibe_saa_CookiesPortlet_cookiesForm"
        }
    ],
    "detectPopup": [
        {
            "visible": "#_es_indra_ibe_saa_CookiesPortlet_cookiesForm"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "[aria-label=\"Accept\\ All\"]"
        }
    ],
    "optOut": [
        {
            "hide": "#_es_indra_ibe_saa_CookiesPortlet_cookiesForm"
        }
    ]
}
