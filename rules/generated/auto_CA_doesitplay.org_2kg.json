{
    "name": "auto_CA_doesitplay.org_2kg",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.doesitplay.org/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?doesitplay\\.org/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookie-consent-banner > div:nth-child(4):not([id]) > button:nth-child(1)#reject-cookies"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookie-consent-banner > div:nth-child(4):not([id]) > button:nth-child(1)#reject-cookies"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookie-consent-banner > div:nth-child(4):not([id]) > button:nth-child(1)#reject-cookies",
            "comment": "I refuse"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookie-consent-banner > div:nth-child(4):not([id]) > button:nth-child(1)#reject-cookies",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
