{
    "name": "auto_NL_krion.com_pyt",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.krion.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?krion\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#modalCook > div#container-cookies > div:nth-child(3):not([id]) > button:nth-child(1):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#modalCook > div#container-cookies > div:nth-child(3):not([id]) > button:nth-child(1):not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#modalCook > div#container-cookies > div:nth-child(3):not([id]) > button:nth-child(1):not([id])",
            "comment": "Reject"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#modalCook > div#container-cookies > div:nth-child(3):not([id]) > button:nth-child(1):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
