{
    "name": "auto_CH_veloteria.ch_k4y",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.veloteria.ch/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?veloteria\\.ch/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookie-information-banner > div:nth-child(2)#cookie_information_link > button:nth-child(2):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookie-information-banner > div:nth-child(2)#cookie_information_link > button:nth-child(2):not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookie-information-banner > div:nth-child(2)#cookie_information_link > button:nth-child(2):not([id])",
            "comment": "Ablehnen"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookie-information-banner > div:nth-child(2)#cookie_information_link > button:nth-child(2):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
