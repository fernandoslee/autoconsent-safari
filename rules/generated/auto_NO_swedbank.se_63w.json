{
    "name": "auto_NO_swedbank.se_63w",
    "cosmetic": true,
    "_metadata": {
        "vendorUrl": "http://www.swedbank.se/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?swedbank\\.se/"
    },
    "prehideSelectors": ["#component-cookie-banner"],
    "detectCmp": [
        {
            "exists": "#component-cookie-banner"
        }
    ],
    "detectPopup": [
        {
            "visible": "#component-cookie-banner"
        }
    ],
    "optIn": [
        {
