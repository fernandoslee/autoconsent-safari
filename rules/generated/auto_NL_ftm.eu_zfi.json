{
    "name": "auto_NL_ftm.eu_zfi",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.ftm.eu/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?ftm\\.eu/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div:not([id]) > button:nth-child(3):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div:not([id]) > button:nth-child(3):not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div:not([id]) > button:nth-child(3):not([id])",
            "comment": "DECLINE"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div:not([id]) > button:nth-child(3):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
