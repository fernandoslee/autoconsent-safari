{
    "name": "auto_CH_gstaadmenuhinfestival.ch_vp3",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.gstaadmenuhinfestival.ch/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?gstaadmenuhinfestival\\.ch/"
    },
    "prehideSelectors": ["#cb-cookie-warning"],
    "detectCmp": [
        {
            "exists": "#cb-cookie-warning"
        }
    ],
    "detectPopup": [
        {
            "visible": "#cb-cookie-warning"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "#cb-cookie-warning__button--accept"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": "#cb-cookie-warning__button--decline"
        }
    ]
}
