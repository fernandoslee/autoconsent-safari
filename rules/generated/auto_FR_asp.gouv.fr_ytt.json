{
    "name": "auto_FR_asp.gouv.fr_ytt",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.asp.gouv.fr/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?asp\\.gouv\\.fr/"
    },
    "prehideSelectors": ["div.fr-consent-banner"],
    "detectCmp": [
        {
            "exists": "div.fr-consent-banner"
        }
    ],
    "detectPopup": [
        {
            "visible": "div.fr-consent-banner"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "[title=\"Accepter\\ tous\\ les\\ cookies\"]"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": "[title=\"Refuser\\ tous\\ les\\ cookies\\ optionnels\"]"
        }
    ]
}
