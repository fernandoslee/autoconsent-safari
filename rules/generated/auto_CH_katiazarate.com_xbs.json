{
    "name": "auto_CH_katiazarate.com_xbs",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.katiazarate.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?katiazarate\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body:nth-child(2) > div:nth-child(15):not([id]).cookie-wrapper > div:nth-child(2):not([id]).cookie-wrap-clickable > a:nth-child(2):not([id]).button.square.w-button"
        }
    ],
    "detectPopup": [
        {
            "visible": "body:nth-child(2) > div:nth-child(15):not([id]).cookie-wrapper > div:nth-child(2):not([id]).cookie-wrap-clickable > a:nth-child(2):not([id]).button.square.w-button"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body:nth-child(2) > div:nth-child(15):not([id]).cookie-wrapper > div:nth-child(2):not([id]).cookie-wrap-clickable > a:nth-child(2):not([id]).button.square.w-button",
            "comment": "ABLEHNEN"
        }
    ],
    "test": [
        {
            "waitForVisible": "body:nth-child(2) > div:nth-child(15):not([id]).cookie-wrapper > div:nth-child(2):not([id]).cookie-wrap-clickable > a:nth-child(2):not([id]).button.square.w-button",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
