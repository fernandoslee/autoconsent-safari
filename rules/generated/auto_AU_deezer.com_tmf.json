{
    "name": "auto_AU_deezer.com_tmf",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.deezer.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?deezer\\.com/"
    },
    "prehideSelectors": ["div.gdpr-modalContainer"],
    "detectCmp": [
        {
            "exists": "div.gdpr-modalContainer"
        }
    ],
    "detectPopup": [
        {
            "visible": "div.gdpr-modalContainer"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "#gdpr-btn-accept-all"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": "#gdpr-btn-refuse-all"
        }
    ]
}
