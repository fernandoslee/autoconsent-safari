{
    "name": "auto_FR_sede.madrid.es_fej",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://sede.madrid.es/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?sede\\.madrid\\.es/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#iam-cookie-control-modal > div:nth-child(2):not([id]) > button:nth-child(2)#iam-cookie-control-modal-action-secondary"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#iam-cookie-control-modal > div:nth-child(2):not([id]) > button:nth-child(2)#iam-cookie-control-modal-action-secondary"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#iam-cookie-control-modal > div:nth-child(2):not([id]) > button:nth-child(2)#iam-cookie-control-modal-action-secondary",
            "comment": "Rechazar todas"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#iam-cookie-control-modal > div:nth-child(2):not([id]) > button:nth-child(2)#iam-cookie-control-modal-action-secondary",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
