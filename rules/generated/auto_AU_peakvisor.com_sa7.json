{
    "name": "auto_AU_peakvisor.com_sa7",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://peakvisor.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?peakvisor\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookies-eu-banner > button:nth-child(2)#cookies-eu-reject"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookies-eu-banner > button:nth-child(2)#cookies-eu-reject"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookies-eu-banner > button:nth-child(2)#cookies-eu-reject",
            "comment": "Reject"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookies-eu-banner > button:nth-child(2)#cookies-eu-reject",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
