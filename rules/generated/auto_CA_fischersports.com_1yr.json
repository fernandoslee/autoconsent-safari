{
    "name": "auto_CA_fischersports.com_1yr",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.fischersports.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?fischersports\\.com/"
    },
    "prehideSelectors": ["#ch2-settings-dialog"],
    "detectCmp": [
        {
            "exists": "#ch2-settings-dialog"
        }
    ],
    "detectPopup": [
        {
            "visible": "#ch2-settings-dialog"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "button.ch2-allow-all-btn"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": "button.ch2-deny-all-btn"
        }
    ]
}
