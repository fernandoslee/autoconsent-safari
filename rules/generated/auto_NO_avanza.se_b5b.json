{
    "name": "auto_NO_avanza.se_b5b",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.avanza.se/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?avanza\\.se/"
    },
    "prehideSelectors": ["div.cookie-banner-content"],
    "detectCmp": [
        {
            "exists": "div.cookie-banner-content"
        }
    ],
    "detectPopup": [
        {
            "visible": "div.cookie-banner-content"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "button.accept-cookie-button"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": "div.column > button:nth-of-type(2)"
        }
    ]
}
