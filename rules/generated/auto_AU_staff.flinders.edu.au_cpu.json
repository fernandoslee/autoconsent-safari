{
    "name": "auto_AU_staff.flinders.edu.au_cpu",
    "vendorUrl": "https://staff.flinders.edu.au/",
    "cosmetic": true,
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?staff\\.flinders\\.edu\\.au/"
