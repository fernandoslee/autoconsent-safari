{
    "name": "auto_FR_missionfranceguichet.fr_irf",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://missionfranceguichet.fr/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?missionfranceguichet\\.fr/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#b-c > div:nth-child(3):not([id]) > a:nth-child(2):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#b-c > div:nth-child(3):not([id]) > a:nth-child(2):not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#b-c > div:nth-child(3):not([id]) > a:nth-child(2):not([id])",
            "comment": "REFUSER"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#b-c > div:nth-child(3):not([id]) > a:nth-child(2):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
