{
    "name": "auto_NO_korge.org_2ao",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://korge.org/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?korge\\.org/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#my-brand-new-cookie-notice > a:nth-child(3)#my-brand-new-cookie-notice-decline"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#my-brand-new-cookie-notice > a:nth-child(3)#my-brand-new-cookie-notice-decline"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#my-brand-new-cookie-notice > a:nth-child(3)#my-brand-new-cookie-notice-decline",
            "comment": "Decline"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#my-brand-new-cookie-notice > a:nth-child(3)#my-brand-new-cookie-notice-decline",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
