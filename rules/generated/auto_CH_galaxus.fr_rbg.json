{
    "name": "auto_CH_galaxus.fr_rbg",
    "cosmetic": true,
    "_metadata": {
        "vendorUrl": "http://www.galaxus.fr/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?galaxus\\.fr/"
    },
    "prehideSelectors": ["dialog"],
    "detectCmp": [
        {
            "exists": "dialog"
        }
    ],
    "detectPopup": [
        {
            "visible": "dialog"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "div.yo7XDsR4 > button:nth-of-type(1)"
        }
    ],
    "optOut": [
        {
            "hide": "dialog"
        }
    ]
}
