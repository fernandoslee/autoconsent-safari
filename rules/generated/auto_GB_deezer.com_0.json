{
    "name": "auto_GB_deezer.com_0",
    "vendorUrl": "https://www.deezer.com/us/",
    "cosmetic": false,
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?deezer\\.com/"
    },
    "prehideSelectors": ["div.gdpr-modalContainer"],
