{
    "name": "auto_DE_bmz.de_nss",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.bmz.de/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?bmz\\.de/"
    },
    "prehideSelectors": ["aside.m-cookie-banner"],
    "detectCmp": [
        {
            "exists": "aside.m-cookie-banner"
        }
    ],
    "detectPopup": [
        {
            "visible": "aside.m-cookie-banner"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "waitForThenClick": "div.m-cookie-banner__choices > button:nth-of-type(2)"
        }
    ]
}
