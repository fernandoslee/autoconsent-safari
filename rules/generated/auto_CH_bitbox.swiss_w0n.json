{
    "name": "auto_CH_bitbox.swiss_w0n",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://bitbox.swiss/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?bitbox\\.swiss/"
    },
    "prehideSelectors": ["div.cookie-monster"],
    "detectCmp": [
        {
            "exists": "div.cookie-monster"
        }
    ],
    "detectPopup": [
        {
            "visible": "div.cookie-monster"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "[data-action=\"accept\"]"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": "[data-action=\"deny\"]"
        }
    ]
}
