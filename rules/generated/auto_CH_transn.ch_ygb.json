{
    "name": "auto_CH_transn.ch_ygb",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.transn.ch/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?transn\\.ch/"
    },
    "prehideSelectors": ["#cookieman-modal"],
    "detectCmp": [
        {
            "exists": "#cookieman-modal"
        }
    ],
    "detectPopup": [
        {
            "visible": "#cookieman-modal"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "div.modal-body > button:nth-of-type(3)"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": "div.modal-body > button:nth-of-type(1)"
        }
    ]
}
