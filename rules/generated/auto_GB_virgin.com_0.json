{
    "name": "auto_GB_virgin.com_0",
    "vendorUrl": "https://www.virgin.com/",
    "cosmetic": false,
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?virgin\\.com/"
    },
    "prehideSelectors": ["div.cookie-modal-box"],
    "detectCmp": [
        {
            "exists": "div.cookie-modal-box"
        }
    ],
    "detectPopup": [
        {
            "visible": "div.cookie-modal-box"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "xpath///button[contains(., 'Accept all')] | //a[contains(., 'Accept all')]"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": "xpath///button[contains(., 'Reject all')] | //a[contains(., 'Reject all')]"
        }
    ]
}
