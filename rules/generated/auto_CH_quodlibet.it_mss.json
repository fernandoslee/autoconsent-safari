{
    "name": "auto_CH_quodlibet.it_mss",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.quodlibet.it/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?quodlibet\\.it/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cp_banner_container > div:nth-child(1):not([id]) > span:nth-child(1):not([id]) > a:nth-child(6):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cp_banner_container > div:nth-child(1):not([id]) > span:nth-child(1):not([id]) > a:nth-child(6):not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cp_banner_container > div:nth-child(1):not([id]) > span:nth-child(1):not([id]) > a:nth-child(6):not([id])",
            "comment": "Solo cookie tecnici"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cp_banner_container > div:nth-child(1):not([id]) > span:nth-child(1):not([id]) > a:nth-child(6):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
