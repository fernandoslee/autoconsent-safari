{
    "name": "auto_GB_filofax.com_uxo",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://filofax.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?filofax\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": ["csm-cookie-consent", ".csm-wrapper"]
        }
    ],
    "detectPopup": [
        {
            "visible": ["csm-cookie-consent", ".csm-wrapper"]
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "if": {
                "exists": ["csm-cookie-consent", ".csm-wrapper .cc-btn-reject"]
            },
            "then": [
                {
                    "waitForThenClick": ["csm-cookie-consent", ".csm-wrapper .cc-btn-reject"]
                }
            ],
            "else": [
                {
                    "if": {
                        "exists": ["csm-cookie-consent", ".csm-wrapper .reject-container button"]
                    },
                    "then": [
                        {
                            "waitForThenClick": ["csm-cookie-consent", ".csm-wrapper .reject-container button"]
                        }
                    ],
                    "else": [
                        {
                            "waitForThenClick": ["csm-cookie-consent", ".csm-wrapper button:nth-child(2)"]
                        }
                    ]
                }
            ]
        }
    ],
    "test": [
        {
            "waitForVisible": ["csm-cookie-consent", ".csm-wrapper"],
            "timeout": 1000,
            "check": "none"
        }
    ]
}
