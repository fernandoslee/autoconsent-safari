        },
        {
            "waitForThenClick": "body > div#cookies > div:not([id]) > p:nth-child(2):not([id]) > a:nth-child(3)#reject_all_noredirect",
            "comment": "RECHAZAR TODAS"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookies > div:not([id]) > p:nth-child(2):not([id]) > a:nth-child(3)#reject_all_noredirect",
            "timeout": 1000,
            "check": "none"
        }
    ]
