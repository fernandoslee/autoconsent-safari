{
    "name": "auto_NL_zuidas.nl_abm",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://zuidas.nl/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?zuidas\\.nl/"
    },
    "prehideSelectors": ["div.c-cookie-bar.js-cookie-bar"],
    "detectCmp": [
        {
            "exists": "div.c-cookie-bar.js-cookie-bar"
        }
    ],
    "detectPopup": [
        {
            "visible": "div.c-cookie-bar.js-cookie-bar"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "waitForThenClick": "button.c-cookie-bar__button.c-cookie-bar__button--reject.js-cookie-reject"
        }
    ]
}
