{
    "name": "auto_DE_speedtest.vodafone.de_dha",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://speedtest.vodafone.de/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?speedtest\\.vodafone\\.de/"
    },
    "prehideSelectors": ["[data-cy=\"modal-dialog\"]"],
    "detectCmp": [
        {
            "exists": "[data-cy=\"modal-dialog\"]"
        }
    ],
    "detectPopup": [
        {
            "visible": "[data-cy=\"modal-dialog\"]"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "[data-cy=\"button-accept-all\"]"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": "xpath///button[contains(., 'Alle ablehnen')] | //a[contains(., 'Alle ablehnen')]"
        }
    ]
}
