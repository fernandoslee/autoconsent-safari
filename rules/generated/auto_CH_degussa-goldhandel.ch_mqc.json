    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?degussa-goldhandel\\.ch/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "dialog[data-nosnippet] a[role='button'][data-order='1']"
        }
    ],
    "detectPopup": [
        {
            "visible": "dialog[data-nosnippet] a[role='button'][data-order='1']"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "dialog[data-nosnippet] a[role='button'][data-order='0']"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": "dialog[data-nosnippet] a[role='button'][data-order='1']"
        }
    ],
    "test": [
        {
            "waitForVisible": "dialog[data-nosnippet] a[role='button'][data-order='1']",
            "timeout": 1000,
            "check": "none"
        }
    ]
