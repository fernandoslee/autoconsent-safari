{
    "name": "auto_FR_pointp.fr_2ft",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.pointp.fr/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?pointp\\.fr/"
    },
    "prehideSelectors": ["#popin_tc_privacy"],
    "detectCmp": [
        {
            "exists": "#popin_tc_privacy"
        }
    ],
    "detectPopup": [
        {
            "visible": "#popin_tc_privacy"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "waitForThenClick": "xpath///button[contains(., 'Continuer sans accepter')] | //a[contains(., 'Continuer sans accepter')]"
        }
    ]
}
