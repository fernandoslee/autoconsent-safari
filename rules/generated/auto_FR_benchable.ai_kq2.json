{
    "name": "auto_FR_benchable.ai_kq2",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://benchable.ai/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?benchable\\.ai/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookie-consent-banner > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(1)#cookie-decline-btn"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookie-consent-banner > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(1)#cookie-decline-btn"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookie-consent-banner > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(1)#cookie-decline-btn",
            "comment": "Decline"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookie-consent-banner > div:not([id]) > div:nth-child(2):not([id]) > button:nth-child(1)#cookie-decline-btn",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
