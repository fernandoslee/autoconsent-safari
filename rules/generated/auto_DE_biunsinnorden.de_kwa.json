{
    "name": "auto_DE_biunsinnorden.de_kwa",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.biunsinnorden.de/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?biunsinnorden\\.de/"
    },
    "prehideSelectors": ["#cookie-note-main"],
    "detectCmp": [
        {
