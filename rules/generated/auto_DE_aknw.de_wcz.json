{
    "name": "auto_DE_aknw.de_wcz",
    "cosmetic": true,
    "_metadata": {
        "vendorUrl": "http://www.aknw.de/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?aknw\\.de/"
    },
    "prehideSelectors": ["div.js-ppwcm-settings__view--start > div:nth-of-type(2)"],
    "detectCmp": [
        {
            "exists": "div.js-ppwcm-settings__view--start > div:nth-of-type(2)"
        }
    ],
    "detectPopup": [
        {
            "visible": "div.js-ppwcm-settings__view--start > div:nth-of-type(2)"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "button.button-primary"
        }
    ],
    "optOut": [
        {
            "hide": "div.js-ppwcm-settings__view--start > div:nth-of-type(2)"
        }
    ]
}
