{
    "name": "auto_CA_rpelectronics.com_nmz",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.rpelectronics.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?rpelectronics\\.com/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#cookieDiag > div:nth-child(2):not([id]) > button:nth-child(1):not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#cookieDiag > div:nth-child(2):not([id]) > button:nth-child(1):not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#cookieDiag > div:nth-child(2):not([id]) > button:nth-child(1):not([id])",
            "comment": "REFUSE"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#cookieDiag > div:nth-child(2):not([id]) > button:nth-child(1):not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
