{
    "name": "auto_FR_haproxy.com_arh",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.haproxy.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?haproxy\\.com/"
    },
    "prehideSelectors": ["#cookie-banner"],
    "detectCmp": [
        {
            "exists": "#cookie-banner"
        }
    ],
    "detectPopup": [
        {
            "visible": "#cookie-banner"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "div.flex > button:nth-of-type(2)"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": "button.btn-transparent"
        }
    ]
}
