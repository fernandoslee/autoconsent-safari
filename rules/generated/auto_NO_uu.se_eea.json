{
    "name": "auto_NO_uu.se_eea",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.uu.se/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?uu\\.se/"
    },
    "prehideSelectors": ["div.sv-cookie-consent-banner"],
    "detectCmp": [
        {
            "exists": "div.sv-cookie-consent-banner"
        }
    ],
    "detectPopup": [
        {
            "visible": "div.sv-cookie-consent-banner"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "xpath///button[contains(., 'Godkänn alla kakor')] | //a[contains(., 'Godkänn alla kakor')]"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": "xpath///button[contains(., 'Godkänn nödvändiga kakor')] | //a[contains(., 'Godkänn nödvändiga kakor')]"
        }
    ]
}
