{
    "name": "auto_CH_bestsecret.com_i8c",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.bestsecret.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?bestsecret\\.com/"
    },
    "prehideSelectors": ["#cmp-banner"],
    "detectCmp": [
        {
            "exists": "#cmp-banner"
        }
    ],
    "detectPopup": [
        {
            "visible": "#cmp-banner"
        }
    ],
    "optIn": [
        {
