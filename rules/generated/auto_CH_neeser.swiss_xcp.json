{
    "name": "auto_CH_neeser.swiss_xcp",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://neeser.swiss/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?neeser\\.swiss/"
    },
    "prehideSelectors": [],
    "detectCmp": [
        {
            "exists": "body > div#sfCookieWarningBar > div:nth-child(2):not([id]) > button:not([id])"
        }
    ],
    "detectPopup": [
        {
            "visible": "body > div#sfCookieWarningBar > div:nth-child(2):not([id]) > button:not([id])"
        }
    ],
    "optIn": [],
    "optOut": [
        {
            "wait": 500
        },
        {
            "waitForThenClick": "body > div#sfCookieWarningBar > div:nth-child(2):not([id]) > button:not([id])",
            "comment": "Ablehnen"
        }
    ],
    "test": [
        {
            "waitForVisible": "body > div#sfCookieWarningBar > div:nth-child(2):not([id]) > button:not([id])",
            "timeout": 1000,
            "check": "none"
        }
    ]
}
