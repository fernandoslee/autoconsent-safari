{
    "name": "auto_CH_airbnb.de_83z",
    "cosmetic": true,
    "_metadata": {
        "vendorUrl": "http://www.airbnb.de/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?airbnb\\.de/"
    },
    "prehideSelectors": ["[data-testid=\"main-cookies-banner-container\"]"],
    "detectCmp": [
        {
            "exists": "[data-testid=\"main-cookies-banner-container\"]"
        }
    ],
    "detectPopup": [
        {
            "visible": "[data-testid=\"main-cookies-banner-container\"]"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "xpath///button[contains(., 'Alle akzeptieren')] | //a[contains(., 'Alle akzeptieren')]"
        }
    ],
    "optOut": [
        {
            "hide": "[data-testid=\"main-cookies-banner-container\"]"
        }
    ]
}
