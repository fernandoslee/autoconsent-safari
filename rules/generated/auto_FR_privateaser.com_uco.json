{
    "name": "auto_FR_privateaser.com_uco",
    "cosmetic": false,
    "_metadata": {
        "vendorUrl": "http://www.privateaser.com/"
    },
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https?://(www\\.)?privateaser\\.com/"
    },
    "prehideSelectors": ["#privacy-banner"],
    "detectCmp": [
        {
            "exists": "#privacy-banner"
        }
    ],
    "detectPopup": [
        {
            "visible": "#privacy-banner"
        }
    ],
    "optIn": [
        {
            "waitForThenClick": "#privacy-accepted"
        }
    ],
    "optOut": [
        {
            "waitForThenClick": "#privacy-rejected"
        }
    ]
}
