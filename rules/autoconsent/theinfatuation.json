{
    "name": "theinfatuation",
    "runContext": {
        "main": true,
        "frame": false,
        "urlPattern": "^https://(www\\.)?theinfatuation\\.com"
    },
    "prehideSelectors": ["#consent-banner"],
    "detectCmp": [{ "exists": "#consent-banner, #onetrust-consent-sdk" }],
    "detectPopup": [{ "waitForVisible": "#consent-banner", "timeout": 10000 }],
    "optIn": [{ "waitForThenClick": "#consent-banner button[data-testid='close-button']" }],
    "optOut": [{ "waitForThenClick": "#consent-banner button[data-testid='close-button']" }],
    "test": [{ "visible": "#consent-banner", "check": "none" }]
}
