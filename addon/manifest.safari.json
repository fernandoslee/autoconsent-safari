{
    "manifest_version": 3,
    "name": "Autoconsent",
    "description": "Automatically opt out of cookie consent popups.",
    "version": "2026.3.31",
    "background": {
        "service_worker": "background.bundle.js"
    },
    "content_scripts": [
        {
            "matches": ["*://*/*"],
            "js": ["content.bundle.js"],
            "run_at": "document_start",
            "all_frames": true
        }
    ],
    "host_permissions": ["*://*/*"],
    "permissions": ["cookies", "tabs", "scripting", "storage", "webNavigation"],
    "action": {
        "default_title": "Autoconsent",
        "default_popup": "popup.html"
    }
}
